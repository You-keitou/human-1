{
  "name": "human-1",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "test": "bun test packages",
    "test:server": "bun test packages/server",
    "e2e": "playwright test",
    "refs:generate": "bun run scripts/export-references.ts",
    "verify:pixels": "bun run refs:generate && bun run scripts/verify-pixels.ts",
    "verify:pixels:only": "bun run scripts/verify-pixels.ts",
    "verify:pixels:bootstrap": "bun run scripts/verify-pixels.ts --allow-missing",
    "typecheck": "bun run --filter '*' typecheck",
    "format": "biome format --write .",
    "lint": "biome lint .",
    "check": "biome check --write ."
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.4",
    "@playwright/test": "^1.61.1",
    "@types/bun": "^1.3.14",
    "@types/pngjs": "^6.0.5",
    "pixelmatch": "^7.2.0",
    "pngjs": "^7.0.0",
    "typescript": "7.0.2"
  }
}
