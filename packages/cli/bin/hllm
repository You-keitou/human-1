#!/usr/bin/env bash
# hllm ランチャ: CLI を常に Node ランタイムで起動する(node-pty TUI を有効化するため)。
# symlink 経由(node_modules/.bin)でも動くよう BASH_SOURCE を辿って実ファイルを解決する。
set -euo pipefail
src="${BASH_SOURCE[0]}"
while [ -h "$src" ]; do
  dir="$(cd -P "$(dirname "$src")" && pwd)"
  src="$(readlink "$src")"
  case "$src" in /*) ;; *) src="$dir/$src" ;; esac
done
dir="$(cd -P "$(dirname "$src")" && pwd)"

# 開発経路(src がある = workspace 内): TS を tsx で直接実行する(拡張子なし import・型ストリップ対応)。
# src を dist より優先することで、prepack 後に残った stale な dist を誤って実行しない。
# tsx バイナリ(ローカル / ルート hoist)を探して起動。無ければ node --import tsx にフォールバック。
entry="$dir/../src/index.ts"
if [ -f "$entry" ]; then
  for c in "$dir/../node_modules/.bin/tsx" "$dir/../../../node_modules/.bin/tsx"; do
    if [ -x "$c" ]; then exec "$c" "$entry" "$@"; fi
  done
  exec node --import tsx "$entry" "$@"
fi

# 公開パッケージ経路(tarball には src が入らない): prepack でバンドル済みの dist を素の Node で実行
# (tsx も workspace 依存も不要 — shared はバンドル済み、node-pty は optional で動的 require)。
exec node "$dir/../dist/index.js" "$@"
